# Normalize line endings to LF on commit; prevents repo-wide CRLF/LF churn
# when the tree is checked out on Windows and operated on from Linux.
* text=auto eol=lf

# Keep binary assets untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
