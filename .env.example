# ============================================================
# LiteratureAI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
VITE_APP_ID=literatureai
JWT_SECRET=your-random-secret-here-min-32-chars

# ── Database (Neon free tier: https://neon.tech) ─────────────
# After creating a Neon project, copy the connection string here
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Google OAuth ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client
# 3. Application type: Web application
# 4. Authorized redirect URIs: http://localhost:3000/api/oauth/callback
#    (add your production URL too when deploying)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OpenAI (LLM prompts + DALL-E 3 image generation) ─────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional: point at an OpenAI-compatible gateway (e.g. Azure OpenAI,
# OpenRouter, a local server). Defaults to the OpenAI API.
# OPENAI_BASE_URL=https://api.openai.com
# Optional: model used for visual-bible + per-page prompt generation.
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=4096
# Optional: image generation model + size.
# IMAGE_MODEL=dall-e-3
# IMAGE_SIZE=1024x1024

# ── Automatic retry worker (failed page reprocessing) ────────
# The worker polls for failed pages and reprocesses them on a backoff.
# Set RETRY_WORKER_ENABLED=false to disable (e.g. in serverless/cron setups).
# RETRY_WORKER_ENABLED=true
# RETRY_WORKER_INTERVAL_MS=30000

# ── Cloudinary (file storage) ────────────────────────────────
# Free tier at https://cloudinary.com — find these in your dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Optional ─────────────────────────────────────────────────
# Your user's openId after first login (format: google_<your-google-id>)
# Set this to give yourself admin access
OWNER_OPEN_ID=google_123456789
