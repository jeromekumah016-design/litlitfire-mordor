# ============================================================
# LiteratureAI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
VITE_APP_ID=literatureai
JWT_SECRET=your-random-secret-here-min-32-chars

# ── Database (Neon free tier: https://neon.tech) ─────────────
# After creating a Neon project, copy the connection string here
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Google OAuth ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client
# 3. Application type: Web application
# 4. Authorized redirect URIs: http://localhost:3000/api/oauth/callback
#    (add your production URL too when deploying)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OpenAI (DALL-E 3 image generation) ───────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Cloudinary (file storage) ────────────────────────────────
# Free tier at https://cloudinary.com — find these in your dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Feature flags ────────────────────────────────────────────
# When "true", the pipeline plans MULTIPLE distinct scenes per book
# (scenePlanner) instead of one image per page. Default off.
SCENE_MODE_ENABLED=false

# ── Offline mode (no-cost, no API keys) ──────────────────────
# When "true", ALL paid boundaries run as local stubs (no OpenAI, no
# Cloudinary): the LLM returns deterministic prompts, image generation
# returns SVG placeholders, and files are stored on local disk and served
# by the app. Lets the full book->photos pipeline run end-to-end with ZERO
# spend. Each boundary also auto-falls-back to offline when its own key is
# missing, so the app runs with no keys at all. Add real keys + leave this
# false (or unset) to use the real services.
OFFLINE_MODE=false
# Optional: override where offline files are written (default ./.offline-storage)
# OFFLINE_STORAGE_DIR=

# ── Optional ─────────────────────────────────────────────────
# Your user's openId after first login (format: google_<your-google-id>)
# Set this to give yourself admin access
OWNER_OPEN_ID=google_123456789
